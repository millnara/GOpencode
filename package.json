{
  "name": "gopencode",
  "version": "1.0.0",
  "private": true,
  "description": "Remote-control opencode sessions from Android (and web).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap sync && cap open android",
    "desktop:build": "cd desktop && go build -ldflags=\"-s -w -H windowsgui\" -o gopencode.exe .",
    "desktop:installer": "cd desktop && build.bat"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.3",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.2.0",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "jsqr": "^1.4.0",
    "native-run": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
